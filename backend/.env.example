# ─── Server ───────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── PostgreSQL ───────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gravit

# ─── MongoDB ──────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/gravit_analytics

# ─── JWT ──────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# ─── Google OAuth ─────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ─── Institution ──────────────────────────────────────
ALLOWED_DOMAIN=iitj.ac.in
INSTITUTION_NAME=IIT Jodhpur
INSTITUTION_SALT=gravit-iitj-salt-2026

# ─── n8n Webhook (optional) ──────────────────────────
N8N_WEBHOOK_URL=http://localhost:5678/webhook/gravit-escalation

# ─── Frontend URL ────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── AI Moderation (optional) ────────────────────────
OPENAI_API_KEY=your-openai-api-key
